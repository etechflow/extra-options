                            <td></td>
                            <td>
                                <input type="number" step="0.01"
                                       name="value_prices[<?= (int)$val['value_id'] ?>]"
                                       value="<?= $escaper->escapeHtmlAttr((string)$val['price']) ?>">
                            </td>
                        </tr>
                    <?php endforeach; ?>
                <?php endforeach; ?>
                </tbody>
            </table>
            <p style="margin-top:14px">
                <button type="submit" class="action-primary"><?= $escaper->escapeHtml(__('Apply Bulk Update')) ?></button>
            </p>
        </div>

        <script>
        (function () {
            var PRODUCTS = <?= /* @noEscape */ $block->getLinkedProductsJson($selectedId) ?>;
            var search = document.getElementById('efbp-search');
            var list   = document.getElementById('efbp-list');
            var chips  = document.getElementById('efbp-chips');
            if (!search) { return; }
            var form = search.closest('form');
            var picked = {};
            function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c];}); }
            function renderList() {
                var q = search.value.trim().toLowerCase();
                list.innerHTML = '';
                if (!q) { list.style.display = 'none'; return; }
                var matches = PRODUCTS.filter(function (p) {
                    return ((p.name || '') + ' ' + (p.sku || '')).toLowerCase().indexOf(q) >= 0;
                }).slice(0, 50);
                if (!matches.length) { list.innerHTML = '<div class="efbp-empty">No matching products in this template</div>'; list.style.display = 'block'; return; }
                matches.forEach(function (p) {
                    var d = document.createElement('div');
                    d.className = 'efbp-item'; d.dataset.id = p.id;
                    d.innerHTML = esc(p.name || ('#' + p.id)) + ' <span class="efbp-sku">(' + esc(p.sku) + ')</span>';
                    list.appendChild(d);
                });
                list.style.display = 'block';
            }
            function renderChips() {
                chips.innerHTML = '';
                form.querySelectorAll('input.efbp-pid').forEach(function (i) { i.remove(); });
                Object.keys(picked).forEach(function (id) {
                    var p = picked[id];
                    var c = document.createElement('span');
                    c.className = 'efbp-chip';
                    c.innerHTML = esc(p.name || ('#' + id)) + ' <span class="efbp-sku">(' + esc(p.sku) + ')</span> <a data-id="' + id + '">&times;</a>';
                    chips.appendChild(c);
                    var inp = document.createElement('input');
                    inp.type = 'hidden'; inp.name = 'product_ids[]'; inp.value = id; inp.className = 'efbp-pid';
                    form.appendChild(inp);
                });
            }
            search.addEventListener('input', renderList);
            search.addEventListener('focus', renderList);
            list.addEventListener('click', function (e) {
                var it = e.target.closest('.efbp-item');
                if (!it) { return; }
                var id = it.dataset.id;
                var p = PRODUCTS.filter(function (x) { return String(x.id) === String(id); })[0];
                if (p) { picked[id] = { name: p.name, sku: p.sku }; renderChips(); }
                search.value = ''; list.style.display = 'none';
            });
            chips.addEventListener('click', function (e) {
                if (e.target.tagName === 'A') { delete picked[e.target.dataset.id]; renderChips(); }
            });
            document.addEventListener('click', function (e) { if (!e.target.closest('.efbp-pick')) { list.style.display = 'none'; } });
        })();
        </script>
    <?php elseif ($selectedId): ?>
        <p style="color:#a00"><?= $escaper->escapeHtml(__('This template has no options yet. Edit it first under Option Templates.')) ?></p>
    <?php endif; ?>
</form>
