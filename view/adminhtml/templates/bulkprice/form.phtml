                        <small style="color:#92400E"><?= $escaper->escapeHtml(__('This template\'s products aren\'t in any category — use the product IDs field on the right instead.')) ?></small>
                    <?php endif; ?>
                </div>
                <div>
                    <label><?= $escaper->escapeHtml(__('Or pick specific product(s) — search by name / SKU')) ?></label>
                    <div class="efbp-pick">
                        <input type="text" id="efbp-search" autocomplete="off" placeholder="<?= $escaper->escapeHtmlAttr(__('Type to search this template\'s products…')) ?>">
                        <div id="efbp-list" class="efbp-list"></div>
                    </div>
                    <div id="efbp-chips" class="efbp-chips"></div>
