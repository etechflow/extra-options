        </div>

        <div class="efopt-bulk-card">
            <h3><?= $escaper->escapeHtml(__('3. New prices')) ?></h3>
            <table class="efopt-bulk-table">
                <thead>
                    <tr>
                        <th><?= $escaper->escapeHtml(__('Option / Value')) ?></th>
                        <th><?= $escaper->escapeHtml(__('Type')) ?></th>
                        <th><?= $escaper->escapeHtml(__('New Price')) ?></th>
                    </tr>
                </thead>
                <tbody>
                <?php foreach ($breakdown as $opt): ?>
                    <tr class="efopt-bulk-option-row">
                        <td><?= $escaper->escapeHtml($opt['title']) ?></td>
                        <td><?= $escaper->escapeHtml($opt['type']) ?></td>
                        <td>
                            <?php if (in_array($opt['type'], ['field','area','file','date','date_time','time'], true)): ?>
                                <input type="number" step="0.01"
                                       name="option_prices[<?= (int)$opt['option_id'] ?>]"
                                       value="<?= $opt['price'] !== null ? $escaper->escapeHtmlAttr((string)$opt['price']) : '' ?>"
                                       placeholder="—">
