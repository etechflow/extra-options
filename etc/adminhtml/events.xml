<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <!-- Gate every admin page under the `efopt` route behind the licence
         (the licence controllers exclude themselves). Admin area only. -->
    <event name="controller_action_predispatch_efopt">
        <observer name="etechflow_optionsplugin_admin_license_gate"
                  instance="Etechflow\OptionsPlugin\Observer\AdminLicenseGate"/>
    </event>

    <!-- Surface the "update available" admin notification when the merchant opens
         the module's License gate or the Stores > Configuration page. -->
    <event name="controller_action_predispatch_efopt_license_gate">
        <observer name="etechflow_optionsplugin_update_notification_gate"
                  instance="Etechflow\OptionsPlugin\Observer\AddUpdateNotification"/>
    </event>
    <event name="controller_action_predispatch_adminhtml_system_config_edit">
        <observer name="etechflow_optionsplugin_update_notification_sysconfig"
                  instance="Etechflow\OptionsPlugin\Observer\AddUpdateNotification"/>
    </event>
</config>
