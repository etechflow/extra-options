<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Register the product-edit form modifier -->
    <virtualType name="Magento\Catalog\Ui\DataProvider\Product\Form\Modifier\Pool" type="Magento\Ui\DataProvider\Modifier\Pool">
        <arguments>
            <argument name="modifiers" xsi:type="array">
                <item name="efopt_templates" xsi:type="array">
                    <item name="class" xsi:type="string">Etechflow\OptionsPlugin\Ui\DataProvider\Product\Form\Modifier\Templates</item>
                    <item name="sortOrder" xsi:type="number">200</item>
                </item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Register the category-edit form modifier -->
    <virtualType name="Magento\Catalog\Ui\DataProvider\Category\Form\Modifier\Pool" type="Magento\Ui\DataProvider\Modifier\Pool">
        <arguments>
            <argument name="modifiers" xsi:type="array">
                <item name="efopt_templates" xsi:type="array">
                    <item name="class" xsi:type="string">Etechflow\OptionsPlugin\Ui\DataProvider\Category\Form\Modifier\Templates</item>
                    <item name="sortOrder" xsi:type="number">200</item>
                </item>
            </argument>
        </arguments>
    </virtualType>
    <!-- Self-contained shared-menu provider: injects eTechFlow::root idempotently
         so this module needs no other eTechFlow module and never declares the
         shared menu id in XML. See Plugin/Adminhtml/EnsureEtechflowMenu.php. -->
    <type name="Magento\Backend\Model\Menu\Builder">
        <plugin name="etechflow_optionsplugin_ensure_root_menu"
                type="Etechflow\OptionsPlugin\Plugin\Adminhtml\EnsureEtechflowMenu"/>
    </type>
</config>
