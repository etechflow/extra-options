<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Backend:etc/menu.xsd">
    <menu>
        <!-- "Extra Options" column under the SHARED eTechFlow sidebar menu.
             eTechFlow::root is declared by module-shipping-table-rates; we only
             REFERENCE it here as the parent. Do NOT re-declare eTechFlow::root —
             Magento's menu schema (uniqueAddItemId) rejects a duplicate id in the
             merged config and fatals the whole admin menu.
             Parent nodes MUST NOT have an action attribute. -->
        <add id="Etechflow_OptionsPlugin::root"
             title="Extra Options"
             module="Etechflow_OptionsPlugin"
             parent="eTechFlow::root"
             sortOrder="60"
             resource="Etechflow_OptionsPlugin::root"/>

        <add id="Etechflow_OptionsPlugin::templates"
             title="Option Templates"
             module="Etechflow_OptionsPlugin"
             parent="Etechflow_OptionsPlugin::root"
             sortOrder="10"
             resource="Etechflow_OptionsPlugin::templates"
             action="efopt/templates/index"/>

        <add id="Etechflow_OptionsPlugin::bulk_price"
             title="Bulk Price Update"
             module="Etechflow_OptionsPlugin"
             parent="Etechflow_OptionsPlugin::root"
             sortOrder="20"
             resource="Etechflow_OptionsPlugin::bulk_price"
             action="efopt/bulkprice/index"/>

        <add id="Etechflow_OptionsPlugin::migration"
             title="Migration Tool"
             module="Etechflow_OptionsPlugin"
             parent="Etechflow_OptionsPlugin::root"
             sortOrder="30"
             resource="Etechflow_OptionsPlugin::migration"
             action="efopt/migration/index"/>

        <add id="Etechflow_OptionsPlugin::license"
             title="License"
             module="Etechflow_OptionsPlugin"
             parent="Etechflow_OptionsPlugin::root"
             sortOrder="40"
             resource="Etechflow_OptionsPlugin::license"
             action="efopt/license/gate"/>
    </menu>
</config>
