<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */
/** @var \Etechflow\OptionsPlugin\ViewModel\OptionDefaults $vm */
$vm = $block->getData('view_model');
if (!$vm) { return; }

$defaults = $vm->getDefaults();
$jsSrc       = $block->getViewFileUrl('Etechflow_OptionsPlugin::js/efopt-live-price.js');
$themeJsSrc  = $block->getViewFileUrl('Etechflow_OptionsPlugin::js/efopt-theme-adopt.js');
$condJsSrc   = $block->getViewFileUrl('Etechflow_OptionsPlugin::js/efopt-conditional.js');
$mfJsSrc     = $block->getViewFileUrl('Etechflow_OptionsPlugin::js/efopt-multifile.js');
?>
<script>
    window.efoptTemplateDefaults = <?= /* @noEscape */ json_encode((object) $defaults) ?>;
    window.efoptCheckboxModes = <?= /* @noEscape */ json_encode((object) $vm->getCheckboxModes()) ?>;
    window.efoptAppearance = <?= /* @noEscape */ json_encode((object) $vm->getAppearance()) ?>;
    window.efoptConditionalFields = <?= /* @noEscape */ json_encode($vm->getConditionalFields()) ?>;
    window.efoptUploadUrl = <?= /* @noEscape */ json_encode($block->getUrl('etechflow/files/upload')) ?>;
</script>
<script src="<?= $escaper->escapeUrl($jsSrc) ?>" defer></script>
<script src="<?= $escaper->escapeUrl($themeJsSrc) ?>" defer></script>
<script src="<?= $escaper->escapeUrl($condJsSrc) ?>" defer></script>
<script src="<?= $escaper->escapeUrl($mfJsSrc) ?>" defer></script>
