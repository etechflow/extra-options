<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">efopt_templates_listing.efopt_templates_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add" class="primary">
                <url path="*/*/newAction"/>
                <label translate="true">Add New Template</label>
            </button>
        </buttons>
        <spinner>efopt_templates_listing_columns</spinner>
        <deps>
            <dep>efopt_templates_listing.efopt_templates_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="efopt_templates_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">template_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Etechflow_OptionsPlugin::templates</aclResource>
        <dataProvider name="efopt_templates_listing_data_source"
                      class="Etechflow\OptionsPlugin\Ui\Component\Listing\TemplateDataProvider">
            <settings>
                <requestFieldName>template_id</requestFieldName>
                <primaryFieldName>template_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Delete the selected templates? Every linked product will have its template-synced options REMOVED from the storefront. Other options added manually outside the template stay intact. This action cannot be undone.</message>
                        <title translate="true">Delete Templates</title>
                    </confirm>
                    <url path="*/*/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="efopt_templates_listing_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>template_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="template_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <editor>
                    <editorType>text</editorType>
                </editor>
                <label translate="true">Name</label>
            </settings>
        </column>
        <column name="options_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true"># Options</label>
            </settings>
        </column>
        <column name="products_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true"># Linked Products</label>
            </settings>
        </column>
        <column name="categories_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true"># Linked Categories</label>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Active</label>
            </settings>
        </column>
        <column name="updated_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Updated At</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Etechflow\OptionsPlugin\Ui\Component\Listing\Column\TemplateActions">
            <settings>
                <indexField>template_id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>107</resizeDefaultWidth>
            </settings>
        </actionsColumn>
    </columns>
</listing>
