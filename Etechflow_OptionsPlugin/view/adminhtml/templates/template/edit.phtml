    $catLevels = $block->getCategoryLevels($linkedCatIds);
    $preL1 = []; $preL2 = []; $preL3 = [];
    foreach ($linkedCatIds as $cid) {
        $lvl = $catLevels[$cid] ?? 2;
        if ($lvl === 2)       { $preL1[] = (int)$cid; }
        elseif ($lvl === 3)   { $preL2[] = (int)$cid; }
        else                  { $preL3[] = (int)$cid; }
