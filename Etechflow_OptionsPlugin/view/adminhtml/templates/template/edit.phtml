<script>
    // Vanilla JS row-cloning. Tracks the next index per option so add/remove
    // doesn't collide with existing rows on submit.
    (function () {
        var nextOptIdx = <?= (int) count($opts) ?>;

        // Build the values-table HTML for a selectable option type. Used both
        // when adding a new row and when the type is changed on an existing row.
        function efoptValuesHtml(optIdx) {
            return '<table class="efopt-values-table">'
                + '<thead><tr>'
                + '<th style="width:50px;text-align:center" title="Default selection on storefront">Default</th>'
                + '<th>Label</th><th style="width:90px">Price</th><th style="width:60px"></th>'
                + '</tr></thead>'
                + '<tbody class="efopt-values-tbody"></tbody>'
                + '<tfoot><tr><td colspan="4" style="text-align:right;padding-top:4px">'
                + '<button type="button" class="efopt-add-btn" onclick="window.efoptAddValueRow(this,' + optIdx + ')">+ Add Value</button>'
                + '</td></tr></tfoot>'
                + '</table>';
        }
        var SELECTABLE_TYPES = ['drop_down','radio','checkbox','multiple'];

        // Called when a type dropdown changes on any row (new or existing).
        window.efoptTypeChanged = function (sel) {
            var row  = sel.closest('tr.efopt-option-row');
            if (!row) return;
            var cell = row.querySelector('td:nth-child(5)');
            var optIdx = parseInt(sel.name.match(/\[(\d+)\]/)[1], 10);
            var type   = sel.value;
            // Show the "single vs multiple" selector ONLY for checkbox type.
            var cbMode = row.querySelector('select.efopt-cb-mode');
            if (cbMode) { cbMode.style.display = (type === 'checkbox') ? '' : 'none'; }
            if (!cell) return;
            if (SELECTABLE_TYPES.indexOf(type) >= 0) {
                // Show values table if not already present.
                if (!cell.querySelector('table.efopt-values-table')) {
                    cell.innerHTML = efoptValuesHtml(optIdx);
                    nextValIdx[optIdx] = nextValIdx[optIdx] || 0;
                }
            } else {
                // Non-selectable type: hide values table.
                if (!cell.querySelector('input[name*="[values]"]')) {
                    cell.innerHTML = '<span style="color:#999;font-size:12px">— not applicable for this type —</span>';
                }
            }
        };

        window.efoptAddOptionRow = function () {
            var tbody = document.querySelector('#efopt-options-table tbody');
            var html = '<tr class="efopt-option-row">'
                + '<td><input type="hidden" name="data[options][' + nextOptIdx + '][option_id]" value="">'
                +     '<input type="text" name="data[options][' + nextOptIdx + '][title]" required></td>'
                + '<td><select name="data[options][' + nextOptIdx + '][type]" class="efopt-type-sel" onchange="window.efoptTypeChanged(this)">'
                +     '<option value="drop_down">Drop-down (single select)</option>'
                +     '<option value="radio">Radio (single select)</option>'
                +     '<option value="checkbox">Checkbox</option>'
                +     '<option value="multiple">Multi-select list</option>'
                +     '<option value="field">Text Field</option>'
                +     '<option value="area">Text Area</option>'
                +     '<option value="file">File Upload</option>'
                + '</select>'
                +     '<select name="data[options][' + nextOptIdx + '][checkbox_mode]" class="efopt-cb-mode" style="margin-top:5px;font-size:11px;display:none">'
                +         '<option value="multi">↳ Customer can tick MULTIPLE</option>'
                +         '<option value="single">↳ Customer can tick ONLY ONE</option>'
                +     '</select></td>'
                + '<td><input type="checkbox" name="data[options][' + nextOptIdx + '][is_required]" value="1"></td>'
                + '<td><input type="number" step="0.01" name="data[options][' + nextOptIdx + '][price]"></td>'
                + '<td>' + efoptValuesHtml(nextOptIdx) + '</td>'
                + '<td><button type="button" class="efopt-del-btn" onclick="this.closest(\'tr.efopt-option-row\').remove()">× Remove</button></td>'
                + '</tr>';
            tbody.insertAdjacentHTML('beforeend', html);
            nextValIdx[nextOptIdx] = 0;
            nextOptIdx++;
        };

        // Per-option value index tracker
        var nextValIdx = {};
        <?php foreach ($opts as $i => $o): ?>
        nextValIdx[<?= $i ?>] = <?= count($o['values'] ?? []) ?>;
        <?php endforeach ?>
        window.efoptAddValueRow = function (btn, optIdx) {
            var tbody = btn.closest('table.efopt-values-table').querySelector('tbody');
            var vIdx = nextValIdx[optIdx] || 0;
            var valueRow = '<tr class="efopt-value-row">'
                + '<td style="text-align:center"><input type="radio" name="data[options][' + optIdx + '][default_value_idx]" value="' + vIdx + '"></td>'
                + '<td><input type="hidden" name="data[options][' + optIdx + '][values][' + vIdx + '][value_id]" value="">'
                +     '<input type="text" name="data[options][' + optIdx + '][values][' + vIdx + '][title]"></td>'
                + '<td><input type="number" step="0.01" name="data[options][' + optIdx + '][values][' + vIdx + '][price]" value="0"></td>'
                + '<td><button type="button" class="efopt-del-btn" onclick="window.efoptRemoveValue(this)">×</button></td>'
                + '</tr>';
            var subRow = '<tr class="efopt-sub-row"><td></td>'
                + '<td colspan="3" style="padding:6px 10px 8px 18px;background:#f6f9ff;border-left:3px solid #0535F5">'
                +   '<div class="efopt-subfields" data-opt="' + optIdx + '" data-val="' + vIdx + '" data-next-sf="0">'
                +     '<div style="font-size:11px;font-weight:600;color:#0535F5;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em">&#8627; Sub-fields — shown on the storefront only when this value is selected</div>'
                +     '<div class="efopt-subfields-list"></div>'
                +     '<button type="button" class="efopt-add-btn" style="font-size:11px;padding:4px 10px" onclick="window.efoptAddSubField(this,' + optIdx + ',' + vIdx + ')">+ Add sub-field</button>'
                +   '</div>'
                + '</td></tr>';
            tbody.insertAdjacentHTML('beforeend', valueRow + subRow);
            nextValIdx[optIdx] = vIdx + 1;
        };

        // Remove a value AND the sub-fields row that follows it.
        window.efoptRemoveValue = function (btn) {
            var row = btn.closest('tr');
            var next = row.nextElementSibling;
            if (next && next.classList.contains('efopt-sub-row')) { next.remove(); }
            row.remove();
        };

        // Append a sub-field editor (label + type + required + price) under a value.
        // Indices come from a per-value counter (data-next-sf) that only grows, so
        // deleting rows never collides keys on submit.
        window.efoptAddSubField = function (btn, optIdx, valIdx) {
            var wrap = btn.closest('.efopt-subfields');
            var list = wrap.querySelector('.efopt-subfields-list');
            var k = parseInt(wrap.dataset.nextSf || '0', 10);
            var base = 'data[options][' + optIdx + '][values][' + valIdx + '][sub_fields][' + k + ']';
            var html = '<div class="efopt-subfield-row" style="border:1px solid #dce7fb;border-radius:5px;background:#fff;padding:8px 10px;margin-bottom:8px">'
                + '<input type="hidden" name="' + base + '[option_id]" value="">'
                + '<div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">'
                +   '<label class="efopt-sf-lbl" style="flex:1;min-width:150px">Title'
                +     '<input type="text" style="width:100%" placeholder="e.g. Enter code" name="' + base + '[title]"></label>'
                +   '<label class="efopt-sf-lbl">Type'
                +     '<select class="efopt-subtype" onchange="window.efoptSubTypeChanged(this)" name="' + base + '[type]" style="width:130px;display:block">'
                +       '<option value="field">Text</option><option value="area">Text Area</option><option value="file">File Upload</option>'
                +       '<option value="drop_down">Drop-down</option><option value="radio">Radio</option><option value="checkbox">Checkbox</option>'
                +     '</select></label>'
                +   '<label class="efopt-sf-lbl efopt-sf-check" style="white-space:nowrap"><input type="checkbox" name="' + base + '[is_required]" value="1"> Required</label>'
                +   '<label class="efopt-sf-lbl">Price<input type="number" step="0.01" style="width:80px;display:block" placeholder="0.00" name="' + base + '[price]"></label>'
                +   '<button type="button" class="efopt-del-btn" style="margin-bottom:2px" onclick="this.closest(\'.efopt-subfield-row\').remove()">×</button>'
                + '</div>'
                + '<div class="efopt-subvalues" style="margin-top:8px;padding-left:12px;border-left:2px dashed #bcd0f5;display:none">'
                +   '<div style="font-size:10.5px;color:#0535F5;font-weight:600;margin-bottom:4px;text-transform:uppercase;letter-spacing:.04em">Choices</div>'
                +   '<div class="efopt-subvalues-list" data-next-sv="0"></div>'
                +   '<button type="button" class="efopt-add-btn" style="font-size:10.5px;padding:3px 8px" onclick="window.efoptAddSubValue(this)">+ Add sub value</button>'
                + '</div>'
                + '</div>';
            list.insertAdjacentHTML('beforeend', html);
            wrap.dataset.nextSf = (k + 1);
        };

        // Show the "Choices" editor only when the sub-field is a selectable type.
        window.efoptSubTypeChanged = function (sel) {
            var row = sel.closest('.efopt-subfield-row');
            var box = row ? row.querySelector('.efopt-subvalues') : null;
            if (!box) { return; }
            var selectable = ['drop_down', 'radio', 'checkbox', 'multiple'].indexOf(sel.value) >= 0;
            box.style.display = selectable ? '' : 'none';
        };

        // Append a choice (label + price) to a selectable sub-field. The name base
        // is derived from the sub-field's hidden option_id input so we never need
        // to thread the option/value indices through.
        window.efoptAddSubValue = function (btn) {
            var box = btn.closest('.efopt-subvalues');
            var list = box.querySelector('.efopt-subvalues-list');
            var row = btn.closest('.efopt-subfield-row');
            var hidden = row.querySelector('input[name$="[option_id]"]');
            var base = hidden.name.replace(/\[option_id\]$/, '');
            var j = parseInt(list.dataset.nextSv || '0', 10);
            var html = '<div class="efopt-subvalue-row" style="display:flex;gap:6px;align-items:center;margin-bottom:4px">'
                + '<input type="hidden" name="' + base + '[sub_values][' + j + '][value_id]" value="">'
                + '<input type="text" style="flex:1" placeholder="Choice label" name="' + base + '[sub_values][' + j + '][title]">'
                + '<input type="number" step="0.01" style="width:80px" placeholder="Price" name="' + base + '[sub_values][' + j + '][price]">'
                + '<button type="button" class="efopt-del-btn" onclick="this.closest(\'.efopt-subvalue-row\').remove()">×</button>'
                + '</div>';
            list.insertAdjacentHTML('beforeend', html);
            list.dataset.nextSv = (j + 1);
        };

    })();

    // ─── Apply-To picker — warning-module pattern: 4 multi-select dropdowns
    //     Level 1 → top-level cats; L2 → children of L1 picks; L3 → children
    //     of L2 picks; L4 → products from selected category set or search.
    //     Multi-select per level. On save, Save.php narrows to deepest selection.
    (function () {
        var TREE = <?= /* @noEscape */ $block->getCategoryTreeJson() ?>;
        var byId = {};
        var byParent = {};
        TREE.forEach(function (c) {
            byId[c.id] = c;
            (byParent[c.parent_id] = byParent[c.parent_id] || []).push(c);
        });

        var productEndpoint  = '<?= /* @noEscape */ $block->getUrl('efopt/templates/categoryProducts') ?>';
        var searchEndpoint   = '<?= /* @noEscape */ $block->getUrl('efopt/templates/searchProducts') ?>';

        // Pre-populated state from server-side render
        var state = {
            cat1: <?= json_encode(array_values(array_map('intval', $preL1))) ?>,
            cat2: <?= json_encode(array_values(array_map('intval', $preL2))) ?>,
            cat3: <?= json_encode(array_values(array_map('intval', $preL3))) ?>,
            products: <?= json_encode(array_map(static fn($p) => [
                'id'   => (int)$p['product_id'],
                'name' => (string)($p['name'] ?? ''),
                'sku'  => (string)($p['sku'] ?? ''),
            ], $preProducts)) ?>,
            productOptions: []   // current dropdown items for product picker
        };

        // ── Helpers ──────────────────────────────────────────────────────
        function el(id) { return document.getElementById(id); }
        function esc(s) {
            return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
            });
        }
        // Mirror Save.php's narrowToDeepest — drop any category whose
        // descendant is also in the selection (by Magento `path` prefix).
        function narrowToDeepest(catIds) {
            if (catIds.length < 2) return catIds.slice();
            // Build paths array from TREE
            var paths = {};
            TREE.forEach(function (c) {
                // we need full path; TREE doesn't expose it, so derive it by walking parents
                var chain = [c.id];
                var cur = c;
                while (cur && cur.parent_id && byId[cur.parent_id]) {
                    chain.unshift(cur.parent_id);
                    cur = byId[cur.parent_id];
                }
                paths[c.id] = chain.join('/');
            });
            return catIds.filter(function (id) {
                var myPath = paths[id];
                if (!myPath) return true;
                return !catIds.some(function (other) {
                    if (other === id) return false;
                    return (paths[other] || '').indexOf(myPath + '/') === 0;
                });
            });
        }

        function syncHidden() {
            var allCats = state.cat1.concat(state.cat2, state.cat3);
            el('ks-input-cats').value = allCats.join(',');
            el('ks-input-products').value = state.products.map(function (p) { return p.id; }).join(',');
            updatePreview(allCats);
        }

        function updatePreview(allCats) {
            var deepest = narrowToDeepest(allCats);
            var parts = [];
            if (deepest.length) {
                var names = deepest.map(function (id) { return byId[id] ? byId[id].name : '#' + id; });
                parts.push('apply to <strong>all products in</strong> '
                    + names.map(function (n) { return '<em>' + n + '</em>'; }).join(', ')
                    + ' <span style="color:#9CA3AF">(plus their sub-categories)</span>');
            }
            if (state.products.length) {
                parts.push('apply directly to <strong>' + state.products.length + ' specific product'
                    + (state.products.length === 1 ? '' : 's') + '</strong>');
            }
            var dropped = allCats.filter(function (id) { return deepest.indexOf(id) < 0; });
            if (dropped.length) {
                var droppedNames = dropped.map(function (id) { return byId[id] ? byId[id].name : '#' + id; });
                parts.push('<span style="color:#92400E">(parent categories ' + droppedNames.join(', ') + ' will be dropped since you also picked their descendants)</span>');
            }
            el('ks-save-preview-text').innerHTML = parts.length
                ? parts.join('; ') + '.'
                : 'nothing selected — save will leave the template unlinked.';
        }
        function pruneChildren() {
            // Drop L2 entries whose parent isn't in L1 anymore
            state.cat2 = state.cat2.filter(function (id) {
                var c = byId[id];
                return c && state.cat1.indexOf(c.parent_id) >= 0;
            });
            // Drop L3 entries whose parent isn't in L2 anymore
            state.cat3 = state.cat3.filter(function (id) {
                var c = byId[id];
                return c && state.cat2.indexOf(c.parent_id) >= 0;
            });
        }

        // ── Render chips into each trigger box ──────────────────────────
        function renderChips() {
            // Categories: chips
            ['cat1','cat2','cat3'].forEach(function (key) {
                var box = el('ks-chips-' + key);
                box.innerHTML = '';
                state[key].forEach(function (id) {
                    var c = byId[id];
                    var chip = document.createElement('span');
                    chip.className = 'ks-chip';
                    chip.innerHTML = esc(c ? c.name : '#' + id)
                        + ' <a data-key="' + key + '" data-id="' + id + '" class="ks-chip-x-cat">×</a>';
                    box.appendChild(chip);
                });
            });
            // Products: chips
            var pbox = el('ks-chips-product');
            pbox.innerHTML = '';
            state.products.forEach(function (p) {
                var chip = document.createElement('span');
                chip.className = 'ks-chip is-product';
                chip.innerHTML = esc(p.name || ('#' + p.id))
                    + ' <span class="ks-sku">(' + esc(p.sku) + ')</span>'
                    + ' <a data-pid="' + p.id + '" class="ks-chip-x-prod">×</a>';
                pbox.appendChild(chip);
            });
            // Show/hide sub-levels — keep a level visible if its parent has
            // selections OR if this level itself already has selections
            // (e.g. reopening a template that was saved with a L3 category
            // but no L2 parent — the chip must still render).
            el('ks-block-cat2').hidden = state.cat1.length === 0 && state.cat2.length === 0;
            el('ks-block-cat3').hidden = state.cat2.length === 0 && state.cat3.length === 0;
            syncHidden();
        }

        // ── Build option lists for each picker pop ──────────────────────
        function getCat1Options(q) {
            q = (q || '').toLowerCase();
            return TREE.filter(function (c) {
                return c.level === 2 && (!q || c.name.toLowerCase().indexOf(q) >= 0);
            });
        }
        function getCat2Options(q) {
            q = (q || '').toLowerCase();
            return TREE.filter(function (c) {
                return c.level === 3
                    && state.cat1.indexOf(c.parent_id) >= 0
                    && (!q || c.name.toLowerCase().indexOf(q) >= 0);
            });
        }
        function getCat3Options(q) {
            q = (q || '').toLowerCase();
            return TREE.filter(function (c) {
                return c.level >= 4
                    && state.cat2.indexOf(c.parent_id) >= 0
                    && (!q || c.name.toLowerCase().indexOf(q) >= 0);
            });
        }

        function renderCatList(key) {
            var list = el('ks-list-' + key);
            var q = el('ks-search-' + key).value;
            var getter = ({cat1: getCat1Options, cat2: getCat2Options, cat3: getCat3Options})[key];
            var items = getter(q);
            list.innerHTML = '';
            if (!items.length) {
                list.innerHTML = '<div class="ks-empty">— ' + (q ? 'No matches' : 'No options') + ' —</div>';
                return;
            }
            items.forEach(function (c) {
                var label = document.createElement('label');
                var checked = state[key].indexOf(c.id) >= 0 ? 'checked' : '';
                label.innerHTML = '<input type="checkbox" data-id="' + c.id + '" data-key="' + key + '" ' + checked + '> '
                    + esc(c.name);
                list.appendChild(label);
            });
        }

        // ── Product list (AJAX) ─────────────────────────────────────────
        var productLoadTimer = null;
        function loadProducts() {
            var q = el('ks-search-product').value.trim();
            var cats = state.cat1.concat(state.cat2, state.cat3).filter(function (id, i, a) {
                return a.indexOf(id) === i;
            });
            // Decide endpoint: free-text search OR category-scoped list
            var url, params;
            if (q.length >= 2) {
                // Free search by name/SKU
                url = searchEndpoint + '?q=' + encodeURIComponent(q);
                if (cats.length) { url += '&category=' + encodeURIComponent(cats.join(',')); }
            } else if (cats.length) {
                // Category-scoped list (first picked cat — backend handles descendants)
                url = productEndpoint + '?category_id=' + encodeURIComponent(cats[0]);
            } else {
                el('ks-list-product').innerHTML = '<div class="ks-empty">Type 2+ chars or pick categories above first.</div>';
                state.productOptions = [];
                return;
            }
            el('ks-list-product').innerHTML = '<div class="ks-empty">Loading…</div>';
            fetch(url, { credentials: 'same-origin', headers: {'X-Requested-With':'XMLHttpRequest'} })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    state.productOptions = data.items || [];
                    renderProductList();
                })
                .catch(function () { el('ks-list-product').innerHTML = '<div class="ks-empty">Error loading.</div>'; });
        }
        function renderProductList() {
            var list = el('ks-list-product');
            list.innerHTML = '';
            if (!state.productOptions.length) {
                list.innerHTML = '<div class="ks-empty">No products found.</div>';
                return;
            }
            var pickedIds = state.products.map(function (p) { return p.id; });
            state.productOptions.forEach(function (p) {
                var label = document.createElement('label');
                var checked = pickedIds.indexOf(p.id) >= 0 ? 'checked' : '';
                label.innerHTML = '<input type="checkbox" data-pid="' + p.id + '" '
                    + 'data-name="' + esc(p.name).replace(/"/g, '&quot;') + '" '
                    + 'data-sku="' + esc(p.sku) + '" ' + checked + '> '
                    + esc(p.name) + ' <span class="ks-sku">(' + esc(p.sku) + ')</span>';
                list.appendChild(label);
            });
        }

        // ── Wire up pickers ──────────────────────────────────────────────
        function openPop(key) {
            ['cat1','cat2','cat3','product'].forEach(function (k) {
                var pop = el('ks-pop-' + k);
                var trig = el('ks-trig-' + k);
                if (k === key) { pop.hidden = false; trig.classList.add('ks-open'); }
                else            { pop.hidden = true;  trig.classList.remove('ks-open'); }
            });
            if (key && key.indexOf('cat') === 0) { renderCatList(key); }
            else if (key === 'product')          { loadProducts(); }
        }
        function closeAll() { openPop(null); }

        ['cat1','cat2','cat3','product'].forEach(function (key) {
            el('ks-trig-' + key).addEventListener('click', function (e) {
                // Ignore clicks on chip ×
                if (e.target.tagName === 'A') return;
                e.stopPropagation();
                var pop = el('ks-pop-' + key);
                if (pop.hidden) { openPop(key); } else { closeAll(); }
            });
        });
        ['cat1','cat2','cat3'].forEach(function (key) {
            el('ks-search-' + key).addEventListener('input', function () { renderCatList(key); });
            el('ks-list-' + key).addEventListener('change', function (e) {
                if (e.target.tagName !== 'INPUT') return;
                var id = parseInt(e.target.dataset.id, 10);
                if (!id) return;
                if (e.target.checked) {
                    if (state[key].indexOf(id) < 0) state[key].push(id);
                } else {
                    state[key] = state[key].filter(function (i) { return i !== id; });
                }
                pruneChildren();
                renderChips();
                if (key === 'cat1') renderCatList('cat2');
                if (key === 'cat2') renderCatList('cat3');
            });
        });
        // Product search input
        el('ks-search-product').addEventListener('input', function () {
            clearTimeout(productLoadTimer);
            productLoadTimer = setTimeout(loadProducts, 250);
        });
        el('ks-list-product').addEventListener('change', function (e) {
            if (e.target.tagName !== 'INPUT') return;
            var pid = parseInt(e.target.dataset.pid, 10);
            if (!pid) return;
            if (e.target.checked) {
                if (!state.products.some(function (p) { return p.id === pid; })) {
                    state.products.push({
                        id: pid,
                        name: e.target.dataset.name || '',
                        sku:  e.target.dataset.sku  || ''
                    });
                }
            } else {
                state.products = state.products.filter(function (p) { return p.id !== pid; });
            }
            renderChips();
        });

        // Chip × handlers (event delegation on document)
        document.addEventListener('click', function (e) {
            if (e.target.classList.contains('ks-chip-x-cat')) {
                e.stopPropagation();
                var key = e.target.dataset.key;
                var id  = parseInt(e.target.dataset.id, 10);
                state[key] = state[key].filter(function (i) { return i !== id; });
                pruneChildren();
                renderChips();
                return;
            }
            if (e.target.classList.contains('ks-chip-x-prod')) {
                e.stopPropagation();
                var pid = parseInt(e.target.dataset.pid, 10);
                state.products = state.products.filter(function (p) { return p.id !== pid; });
                renderChips();
                return;
            }
            // Outside click closes pops
            if (!e.target.closest('.ks-picker')) { closeAll(); }
        });

        // Initial paint
        renderChips();
    })();
</script>
