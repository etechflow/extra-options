<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="200">
            <label>eTechFlow</label>
        </tab>
        <section id="etechflow_options"
                 translate="label"
                 type="text"
                 sortOrder="10"
                 showInDefault="1"
                 showInWebsite="1"
                 showInStore="1">
            <label>Extra Options Plugin</label>
            <tab>etechflow</tab>
            <resource>Etechflow_OptionsPlugin::config</resource>

            <group id="module_status" translate="label" type="text" sortOrder="1"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Module Status</label>
                <frontend_model>Etechflow\OptionsPlugin\Block\Adminhtml\System\Config\ModuleStatus</frontend_model>
            </group>

            <group id="license" translate="label" type="text" sortOrder="5"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>

                <field id="production_environment" translate="label comment" type="select"
                       sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Production Environment</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[
                        <strong>Yes</strong> = live site. License key required to use the admin Option-Templates tools.<br/>
                        <strong>No</strong> = dev/staging. Admin tools run without a key.
                    ]]></comment>
                </field>

                <field id="license_key" translate="label comment" type="text"
                       sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <comment><![CDATA[
                        Auto-populated after Stripe purchase. Format: <code>SP-XXXX-XXXX-XXXX-XXXX</code>.<br/>
                        Bound to your domain. <code>www.</code> prefix normalised — one key works for both.
                    ]]></comment>
                </field>

                <field id="portal_url" translate="label comment" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[
                        URL of the eTechFlow license portal. Called by the Magento server to validate
                        SP-XXXX keys and complete Stripe activation.<br/>
                        Example: <code>https://your-tunnel.ngrok-free.dev</code> or your production portal URL.
                    ]]></comment>
                </field>

                <field id="portal_api_url" translate="label comment" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Validation API URL (optional override)</label>
                    <comment><![CDATA[
                        Optional override for the server-to-server validation URL.
                        If blank, the Portal URL above is used.
                    ]]></comment>
                </field>
            </group>

            <group id="payment" translate="label" type="text" sortOrder="7"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Payment (Stripe)</label>
                <comment><![CDATA[Add your Stripe REST API credentials to enable "Select Plan &amp; Pay" on the gate page. Get them at https://dashboard.stripe.com/test/apikeys.]]></comment>

                <field id="stripe_secret_key" translate="label" type="obscure"
                       sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Stripe Secret Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[
                        <code>sk_test_...</code> or <code>sk_live_...</code>. Stored encrypted by Magento.
                    ]]></comment>
                </field>

                <field id="stripe_publishable_key" translate="label" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Stripe Publishable Key</label>
                    <comment><![CDATA[
                        <code>pk_test_...</code> or <code>pk_live_...</code>. Public — safe to display.
                    ]]></comment>
                </field>

                <field id="stripe_currency" translate="label" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Currency</label>
                    <comment><![CDATA[Three-letter Stripe currency code, lowercase. Default: <code>usd</code>.]]></comment>
                </field>
            </group>

            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Master switch for the entire module.</comment>
                </field>
            </group>

            <group id="file_options" translate="label" type="text" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>File Upload Behaviour</label>

                <field id="soft_required" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Soft-Required File Options</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[When <strong>Yes</strong>, customers can add a product to cart even if a file-type custom option is empty. Fixes Magento's hard "required option(s) weren't entered" error for file uploads.]]></comment>
                </field>

                <field id="log_relaxed" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Log Relaxed File Validations</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Write a debug line to var/log/system.log every time a file requirement is relaxed.</comment>
                    <depends>
                        <field id="soft_required">1</field>
                    </depends>
                </field>
            </group>

            <group id="smart_card" translate="label" type="text" sortOrder="30"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Frontend Radio-Card</label>
                <comment><![CDATA[Used when a product page has a primary radio/dropdown option with related code/image inputs (e.g. "Would you like us to cut this?"). The frontend groups these into a single radio card. Manage option SETS centrally via <strong>eTechFlow &rarr; Option Templates</strong>.]]></comment>

                <field id="default_choice" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default Selected Choice</label>
                    <source_model>Etechflow\OptionsPlugin\Model\Source\DefaultChoice</source_model>
                    <comment><![CDATA[Which radio is preselected on PDP load. <strong>None</strong> = customer must actively pick.]]></comment>
                </field>
            </group>

            <group id="appearance" translate="label" type="text" sortOrder="40"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Appearance</label>
                <comment><![CDATA[Make the product-option UI blend into <strong>any</strong> active theme (Luma, Adobe Commerce, Hyvä, or custom). Colours are read live from the running theme — nothing is hard-coded.]]></comment>

                <field id="adopt_theme_colors" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Adopt Theme Colours</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[When <strong>Yes</strong>, the extension auto-detects the active theme's accent, text and border colours at runtime and styles the options to match. Works on Luma, Adobe Commerce, Hyvä and custom themes.]]></comment>
                </field>

                <field id="card_layout" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Themed Option Cards</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Render each choice as a bordered card that highlights in the theme colour when selected. Set to <strong>No</strong> to keep your theme's native option layout and only adopt colours.]]></comment>
                </field>

                <field id="accent_color" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Accent Colour Override</label>
                    <comment><![CDATA[Optional. A hex colour like <strong>#1979c3</strong> to force the accent. Leave blank to auto-use the colour detected from the live theme.]]></comment>
                    <depends><field id="adopt_theme_colors">1</field></depends>
                </field>
            </group>
        </section>
    </system>
</config>
